## ============================================================================
## SCRIPTWATCH STANDALONE CONFIGURATION
## ============================================================================
## Run: ./tools/setup-env.sh to generate this file interactively
## ============================================================================

## DATABASE & STORAGE
## Docker and Unraid should keep these container paths as-is.
## Map /app/data to a persistent host folder in docker-compose.yml or Unraid.
DATABASE_URL=sqlite:////app/data/scriptwatch.db
DATA_DIR=/app/data
SCRIPT_STORE_DIR=/app/data/script-store

## REQUIRED: Security Keys
## Generate unique values for EACH new install. Never reuse or share these.
## Run: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AGENT_TOKEN=generate_a_long_random_string_here
SECRET_KEY=generate_a_long_random_string_here

## REQUIRED: Public URL
## Set this to your actual server address (used in install commands for agents)
## Examples:
##   - http://192.168.1.50:8080 (local network)
##   - https://scriptwatch.example.com (public domain with TLS)
##   - http://localhost:8080 (development only)
BASE_URL=http://localhost:8080

## ADMIN CREDENTIALS (optional but recommended)
## Leave ADMIN_PASSWORD empty to set it via the UI on first login
## ADMIN_TOKEN is generated in settings for CLI/API access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=

## NOTIFICATIONS (optional)
## Leave blank to disable. Supported: ntfy.sh, Discord
NTFY_URL=
NTFY_TOKEN=
DISCORD_WEBHOOK_URL=

## JOB SCHEDULING (optional)
## Grace period for detecting missed scheduled runs (in minutes)
MISSED_RUN_GRACE_MINUTES=15
JOB_RETENTION_DAYS=30

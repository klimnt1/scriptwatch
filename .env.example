# ScriptWatch Standalone stores everything locally in ./data by default.
DATABASE_URL=sqlite:////app/data/scriptwatch.db
DATA_DIR=/app/data
SCRIPT_STORE_DIR=/app/data/script-store

# Generate unique values for each install. Do not reuse someone else's token.
AGENT_TOKEN=generate_a_long_random_string_here
SECRET_KEY=generate_a_long_random_string_here

# Optional: enable browser/admin API authentication when set.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Set to your public URL so install scripts and agent tokens use the right address.
# Example: http://192.168.1.50:8080 or https://scriptwatch.example.com
BASE_URL=http://localhost:8080

# Optional notifications.
NTFY_URL=
NTFY_TOKEN=
DISCORD_WEBHOOK_URL=
MISSED_RUN_GRACE_MINUTES=15
